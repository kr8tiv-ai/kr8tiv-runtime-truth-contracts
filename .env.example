# KIN Platform Environment Variables

# =============================================================================
# Required
# =============================================================================

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# JWT Authentication (random secure string)
JWT_SECRET=your_secure_jwt_secret_here

# =============================================================================
# Local LLM (Ollama)
# =============================================================================

OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2

# Enable local Whisper transcription
LOCAL_WHISPER_ENABLED=false
LOCAL_WHISPER_PATH=whisper

# =============================================================================
# Cloud Fallback (recommended)
# =============================================================================

# OpenAI (for fallback LLM and Whisper transcription)
OPENAI_API_KEY=

# Anthropic (alternative fallback)
ANTHROPIC_API_KEY=

# =============================================================================
# Voice Processing
# =============================================================================

# ElevenLabs (TTS voice synthesis)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# =============================================================================
# Database & Server
# =============================================================================

DATABASE_PATH=./data/kin.db
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# =============================================================================
# Solana (NFT Integration)
# =============================================================================

SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=

# =============================================================================
# Tailscale (Remote Access)
# =============================================================================

TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# =============================================================================
# Web Search (Skills)
# =============================================================================

# Tavily (https://tavily.com — free tier available)
TAVILY_API_KEY=

# =============================================================================
# Monitoring & Notifications
# =============================================================================

SLACK_WEBHOOK_URL=
ALERT_CHAT_ID=
