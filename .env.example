# KIN Platform Environment Variables

# =============================================================================
# Required
# =============================================================================

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Owner Telegram user ID (gets full admin access via Tailscale trust ladder)
# Find your ID: send /start to @userinfobot on Telegram
OWNER_TELEGRAM_ID=

# JWT Authentication (random secure string)
JWT_SECRET=your_secure_jwt_secret_here

# =============================================================================
# Local LLM (Ollama)
# =============================================================================

OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2

# =============================================================================
# Local Voice Pipeline (zero-cost, open source)
# =============================================================================

# Local STT — whisper.cpp (https://github.com/ggerganov/whisper.cpp)
LOCAL_WHISPER_ENABLED=false
WHISPER_CPP_PATH=whisper-cpp
WHISPER_MODEL_PATH=
WHISPER_THREADS=4

# Local TTS — XTTS v2 for voice cloning (https://github.com/coqui-ai/TTS)
# Start server: tts --model_name tts_models/multilingual/multi-dataset/xtts_v2 --server
XTTS_SERVER_URL=http://localhost:8020
LOCAL_TTS_PROVIDER=xtts
VOICE_PROFILES_DIR=./voice/profiles

# Local TTS — Piper fallback (https://github.com/rhasspy/piper)
PIPER_PATH=piper
PIPER_MODEL_PATH=

# =============================================================================
# Supervisor (frontier model — the "expert on call")
# =============================================================================

# Provider: 'openai' or 'anthropic'
SUPERVISOR_PROVIDER=anthropic

# Escalation level: how eagerly your KIN calls the supervisor
#   'low'    — only for very complex tasks
#   'medium' — balanced (recommended)
#   'high'   — escalates more often
#   'always' — every message goes to supervisor
#   'never'  — local only, supervisor disabled
SUPERVISOR_ESCALATION=medium

# =============================================================================
# Cloud API Keys (powers both supervisor and fallback)
# Priority: Groq (free) → Anthropic → OpenAI
# =============================================================================

# Groq (FREE — 500K tokens/day, no credit card, Qwen 3 32B)
# Sign up: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# OpenAI (for supervisor/fallback LLM and Whisper transcription)
OPENAI_API_KEY=

# Anthropic (for supervisor/fallback LLM)
ANTHROPIC_API_KEY=

# =============================================================================
# Voice Processing
# =============================================================================

# ElevenLabs (TTS voice synthesis)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# =============================================================================
# Database & Server
# =============================================================================

DATABASE_PATH=./data/kin.db
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# =============================================================================
# Solana (NFT Integration — powered by 3D Anvil CC0)
# =============================================================================

SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Admin keypair for server-side Candy Machine minting (base58-encoded secret key)
SOLANA_ADMIN_KEYPAIR=

# KIN companion collection mint address (set after deployment)
NEXT_PUBLIC_KIN_COLLECTION_MINT=

# Per-companion Candy Machine addresses (set after deployment)
NEXT_PUBLIC_CM_CIPHER=
NEXT_PUBLIC_CM_MISCHIEF=
NEXT_PUBLIC_CM_VORTEX=
NEXT_PUBLIC_CM_FORGE=
NEXT_PUBLIC_CM_AETHER=
NEXT_PUBLIC_CM_CATALYST=

# Server-side Candy Machine addresses (same values, no NEXT_PUBLIC_ prefix)
CM_CIPHER=
CM_MISCHIEF=
CM_VORTEX=
CM_FORGE=
CM_AETHER=
CM_CATALYST=

# =============================================================================
# Tailscale (Remote Access)
# =============================================================================

TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# =============================================================================
# Web Search (Skills)
# =============================================================================

# Tavily (https://tavily.com — free tier available)
TAVILY_API_KEY=

# =============================================================================
# Stripe Billing (skip for MVP — billing works gracefully without keys)
# =============================================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# =============================================================================
# Vercel (website deployment)
# =============================================================================

VERCEL_TOKEN=

# =============================================================================
# Webhook Mode (production — set to your public HTTPS URL)
# Leave empty to use polling mode (development)
# =============================================================================

WEBHOOK_URL=
WEBHOOK_SECRET=

# =============================================================================
# Frontier Model Providers (companion-specific AI brains)
# =============================================================================

# xAI — Grok 4.20 (powers Forge)
XAI_API_KEY=

# Z.ai (Zhipu AI) — GLM-4.6 (powers Catalyst)
ZAI_API_KEY=

# Google — Gemini 3.1 Pro (powers Mischief)
GOOGLE_AI_API_KEY=

# Moonshot AI — Kimi K2.5 (powers Aether)
MOONSHOT_API_KEY=

# =============================================================================
# Supermemory.ai (intelligent companion memory)
# =============================================================================

# Get your API key: https://supermemory.ai
SUPERMEMORY_API_KEY=

# =============================================================================
# Discord Bot
# =============================================================================

DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# =============================================================================
# WhatsApp Bot (Baileys multi-file auth)
# =============================================================================

WHATSAPP_AUTH_DIR=./data/whatsapp-auth

# =============================================================================
# Monitoring & Notifications
# =============================================================================

SLACK_WEBHOOK_URL=
ALERT_CHAT_ID=

# =============================================================================
# Heartbeat & Recovery (local KIN → VPS)
# =============================================================================

HEARTBEAT_INTERVAL_MS=30000
HEARTBEAT_TIMEOUT_MS=90000
VPS_HEARTBEAT_URL=
HEARTBEAT_API_KEY=
